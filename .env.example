# ── LLM provider ─────────────────────────────────────────────────────────────
# Options: ollama | anthropic | openai  (default: ollama)
LLM_PROVIDER=ollama

# Ollama (default — no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:latest

# Anthropic / Claude (set LLM_PROVIDER=anthropic to use)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI (set LLM_PROVIDER=openai to use)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── MS SQL Server ─────────────────────────────────────────────────────────────
MSSQL_HOST=localhost
MSSQL_PORT=1433
MSSQL_USER=sa
MSSQL_PASSWORD=Rossmann@13June
MSSQL_DATABASE=Rossmann
